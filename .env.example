# ── Required ─────────────────────────────────────────────────────────────────
# Public URL of your instance (used for links, cookies and CORS).
CAIRN_BASE_URL=https://start.example.com
# HMAC key for session tokens — min 32 chars. Generate: openssl rand -base64 32
CAIRN_SESSION_SECRET=change-me-with-openssl-rand-base64-32

# ── Registration / security (important for public instances) ─────────────────
# Set to false for any public-facing instance (the first registrant becomes owner).
CAIRN_OPEN_REGISTRATION=false
# Browser session lifetime in days (also drives the cookie max-age).
CAIRN_SESSION_LIFETIME_DAYS=30
# Keep true ONLY behind a reverse proxy; set false if Cairn is exposed directly.
CAIRN_TRUSTED_PROXY=true

# ── SMTP (needed to send invitation / setup / share emails) ──────────────────
CAIRN_SMTP_HOST=smtp.example.com
CAIRN_SMTP_PORT=587
CAIRN_SMTP_USER=user@example.com
CAIRN_SMTP_PASS=your-smtp-password
CAIRN_SMTP_FROM=Cairn <no-reply@example.com>
CAIRN_SMTP_TLS=true

# ── Optional ─────────────────────────────────────────────────────────────────
# CAIRN_ENV=production            # production | development
# CAIRN_TOTP_ISSUER=Cairn
# CAIRN_INVITE_LIFETIME=72        # invite link lifetime, hours
# OIDC / SSO (Authentik, Keycloak, Authelia, Google…)
# CAIRN_OIDC_ISSUER=
# CAIRN_OIDC_CLIENT_ID=
# CAIRN_OIDC_CLIENT_SECRET=
# CAIRN_OIDC_PROVIDER_NAME=SSO
